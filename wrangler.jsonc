{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "recycling-bot",
    "main": "./src/worker.mjs",
    "compatibility_date": "2026-05-18",
    "assets": {
        "directory": "./public/",
        "binding": "ASSETS",
        "run_worker_first": [
            "/api/*"
        ]
    },
    "secrets": {
        "required": [
            "OPENROUTER_API_KEY"
        ]
    }
}
